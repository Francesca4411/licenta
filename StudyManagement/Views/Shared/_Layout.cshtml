<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyManagement</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudyManagement.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="sp-shell" data-theme="light" data-sidebar="expanded">
        <aside class="sp-sidebar" id="appSidebar" aria-label="Application">
            <div class="sp-brand-row">
                <div class="sp-brand">
                    <div class="sp-brand-icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                            <path d="M4 6.5C4 5.12 5.12 4 6.5 4H20v16H6.5C5.12 20 4 18.88 4 17.5V6.5Z" fill="currentColor" opacity="0.25"/>
                            <path d="M6.5 6H20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <path d="M7 20V4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </div>
                    <div class="sp-brand-text">
                        <div class="sp-brand-title">Study Planner</div>
                        <div class="sp-brand-subtitle">Plan your studies</div>
                    </div>
                </div>
                <button type="button" class="sp-sidebar-collapse" id="sidebarToggle" aria-expanded="true" aria-controls="sidebarNavGroups" title="Collapse menu">
                    <span class="sp-sidebar-collapse-icon" aria-hidden="true">‹</span>
                </button>
            </div>

            <div class="sp-sidebar-nav-wrap" id="sidebarNavGroups">
                <div class="sp-nav-group">
                    <div class="sp-nav-group-title">Planning</div>
                    <nav class="sp-nav" aria-label="Planning">
                        <a class="sp-nav-item" asp-controller="Home" asp-action="Index" title="Dashboard">
                            <span class="sp-nav-icon" aria-hidden="true">▦</span>
                            <span class="sp-nav-label">Dashboard</span>
                        </a>
                        <a class="sp-nav-item" asp-controller="Subjects" asp-action="Index" title="Subjects">
                            <span class="sp-nav-icon" aria-hidden="true">▤</span>
                            <span class="sp-nav-label">Subjects</span>
                        </a>
                        <a class="sp-nav-item" asp-controller="Calendar" asp-action="Index" title="Calendar">
                            <span class="sp-nav-icon" aria-hidden="true">🗓</span>
                            <span class="sp-nav-label">Calendar</span>
                        </a>
                    </nav>
                </div>
                <div class="sp-nav-group">
                    <div class="sp-nav-group-title">Progress</div>
                    <nav class="sp-nav" aria-label="Progress">
                        <a class="sp-nav-item" asp-controller="StudySessions" asp-action="Index" title="Study Sessions">
                            <span class="sp-nav-icon" aria-hidden="true">⏱</span>
                            <span class="sp-nav-label">Study Sessions</span>
                        </a>
                        <a class="sp-nav-item" asp-controller="Pomodoro" asp-action="Index" title="Pomodoro">
                            <span class="sp-nav-icon" aria-hidden="true">⏲</span>
                            <span class="sp-nav-label">Pomodoro</span>
                        </a>
                    </nav>
                </div>
                <div class="sp-nav-group">
                    <div class="sp-nav-group-title">Account</div>
                    <nav class="sp-nav" aria-label="Account">
                        <a class="sp-nav-item" asp-controller="AiTutor" asp-action="Index" title="AI Tutor">
                            <span class="sp-nav-icon" aria-hidden="true">🤖</span>
                            <span class="sp-nav-label">AI Tutor</span>
                        </a>
                        <a class="sp-nav-item" asp-controller="Profile" asp-action="Index" title="Profile">
                            <span class="sp-nav-icon" aria-hidden="true">👤</span>
                            <span class="sp-nav-label">Profile</span>
                        </a>
                    </nav>
                </div>
                @if (User.IsInRole("Admin"))
                {
                    <div class="sp-nav-group">
                        <div class="sp-nav-group-title">Admin</div>
                        <nav class="sp-nav" aria-label="Admin">
                            <a class="sp-nav-item" asp-controller="Admin" asp-action="Index" title="Users">
                                <span class="sp-nav-icon" aria-hidden="true">👥</span>
                                <span class="sp-nav-label">Users</span>
                            </a>
                        </nav>
                    </div>
                }
            </div>

            <div class="sp-sidebar-bottom">
                <button type="button" class="sp-theme-toggle" id="themeToggle">
                    <span class="sp-theme-toggle-icon" aria-hidden="true">☾</span>
                    <span class="sp-theme-toggle-label" id="themeToggleLabel">Dark Mode</span>
                </button>
            </div>
        </aside>

        <div class="sp-main">
            <header class="sp-topbar" role="banner">
                <div class="sp-topbar-actions">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <span class="sp-topbar-user-wrap">
                            <span class="sp-topbar-user" title="Signed in">@User.Identity!.Name</span>
                        </span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="sp-topbar-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="sp-topbar-btn sp-topbar-btn-outline">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="sp-topbar-btn sp-topbar-btn-outline">Login</a>
                        <a asp-controller="Account" asp-action="Register" class="sp-topbar-btn sp-topbar-btn-primary">Register</a>
                    }
                </div>
            </header>
            @{
                var mainClass = ViewData["MainContentClass"] as string;
                var innerClass = ViewData["ContentInnerClass"] as string;
            }
            <main class="sp-content @(mainClass ?? "")">
                @await Html.PartialAsync("_Breadcrumbs")
                <div class="sp-content-inner @(innerClass ?? "")">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script>
        (function () {
            const root = document.querySelector('.sp-shell');
            const toggle = document.getElementById('themeToggle');
            const label = document.getElementById('themeToggleLabel');
            const icon = toggle?.querySelector('.sp-theme-toggle-icon');

            function applyTheme(theme) {
                root?.setAttribute('data-theme', theme);
                const isDark = theme === 'dark';
                if (label) label.textContent = isDark ? 'Light Mode' : 'Dark Mode';
                if (icon) icon.textContent = isDark ? '☀' : '☾';
                document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
            }

            const saved = localStorage.getItem('sp-theme');
            const theme = saved === 'dark' ? 'dark' : 'light';
            applyTheme(theme);

            toggle?.addEventListener('click', function () {
                const current = root?.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
                const next = current === 'dark' ? 'light' : 'dark';
                localStorage.setItem('sp-theme', next);
                applyTheme(next);
            });

            const sidebarToggle = document.getElementById('sidebarToggle');
            const collapseIcon = sidebarToggle?.querySelector('.sp-sidebar-collapse-icon');

            function applySidebar(collapsed) {
                if (!root) return;
                root.setAttribute('data-sidebar', collapsed ? 'collapsed' : 'expanded');
                if (sidebarToggle) {
                    sidebarToggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
                    sidebarToggle.title = collapsed ? 'Expand menu' : 'Collapse menu';
                }
                if (collapseIcon) collapseIcon.textContent = collapsed ? '›' : '‹';
            }

            function syncSidebarForViewport() {
                if (!root) return;
                if (!window.matchMedia('(min-width: 821px)').matches) {
                    root.setAttribute('data-sidebar', 'expanded');
                    if (sidebarToggle) {
                        sidebarToggle.setAttribute('aria-expanded', 'true');
                        sidebarToggle.title = 'Collapse menu';
                    }
                    if (collapseIcon) collapseIcon.textContent = '‹';
                    return;
                }
                const savedSidebar = localStorage.getItem('sp-sidebar');
                const collapsed = savedSidebar === 'collapsed';
                applySidebar(collapsed);
            }

            sidebarToggle?.addEventListener('click', function () {
                if (!window.matchMedia('(min-width: 821px)').matches) return;
                const collapsed = root?.getAttribute('data-sidebar') !== 'collapsed';
                applySidebar(collapsed);
                localStorage.setItem('sp-sidebar', collapsed ? 'collapsed' : 'expanded');
            });

            window.addEventListener('resize', syncSidebarForViewport);
            syncSidebarForViewport();

            const path = (window.location.pathname || '').toLowerCase();
            document.querySelectorAll('.sp-nav-item').forEach(a => {
                const href = (a.getAttribute('href') || '').toLowerCase();
                if (!href || href === '#') return;
                if (path === href || (href !== '/' && path.startsWith(href))) a.classList.add('active');
            });
        })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
