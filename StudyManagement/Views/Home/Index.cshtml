@model StudyManagement.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="sp-page-airy">
<header class="sp-page-header">
    <div class="sp-hello">
        <h1>Welcome back, @Model.WelcomeName! <span class="sp-wave" aria-hidden="true">👋</span></h1>
        <div class="sp-date">@Model.TodayLabel</div>
    </div>
</header>

<section class="sp-stats" aria-label="Quick stats">
    <div class="sp-stat sp-grad-purple">
        <div class="sp-stat-top">
            <div class="sp-stat-title">Active Subjects</div>
            <div class="sp-stat-icon" aria-hidden="true">📚</div>
        </div>
        <div class="sp-stat-value">@Model.ActiveSubjects</div>
    </div>

    <div class="sp-stat sp-grad-magenta">
        <div class="sp-stat-top">
            <div class="sp-stat-title">Upcoming Exams</div>
            <div class="sp-stat-icon" aria-hidden="true">🗓</div>
        </div>
        <div class="sp-stat-value">@Model.UpcomingExams</div>
    </div>

    <div class="sp-stat sp-grad-pinkred">
        <div class="sp-stat-top">
            <div class="sp-stat-title">Sessions Today</div>
            <div class="sp-stat-icon" aria-hidden="true">⏱</div>
        </div>
        <div class="sp-stat-value">@Model.SessionsToday</div>
    </div>

    <div class="sp-stat sp-grad-indigo">
        <div class="sp-stat-top">
            <div class="sp-stat-title">Hours This Week</div>
            <div class="sp-stat-icon" aria-hidden="true">↗</div>
        </div>
        <div class="sp-stat-value">@Model.HoursThisWeekLabel</div>
    </div>
</section>

<section class="sp-grid-2" aria-label="Recommendations and evaluations">
    <div class="sp-panel">
        <div class="sp-panel-header">
            <div class="sp-panel-badge" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2a7 7 0 0 0-4 12.74V18a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-3.26A7 7 0 0 0 12 2Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M10 22h4" stroke="white" stroke-width="2" stroke-linecap="round" />
                </svg>
            </div>
            <h2 class="sp-panel-title">Smart Recommendations</h2>
        </div>
        <div class="sp-panel-body">
            @foreach (var rec in Model.Recommendations)
            {
                <div class="sp-note sp-note--recommendation">
                    <span class="sp-rec-title">@rec.Title:</span> @rec.Message
                </div>
            }
        </div>
    </div>

    <div class="sp-panel">
        <div class="sp-panel-header">
            <div class="sp-panel-badge" aria-hidden="true" style="background: linear-gradient(145deg, #4a9fe0, #6fc0f4); color: rgba(255,255,255,0.98); border: 0;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M7 2v3M17 2v3" stroke="white" stroke-width="2" stroke-linecap="round" />
                    <path d="M3.5 9h17" stroke="white" stroke-width="2" stroke-linecap="round" />
                    <path d="M6 5h12a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <h2 class="sp-panel-title">Upcoming Evaluations</h2>
        </div>
        <div class="sp-panel-body">
            @if (Model.UpcomingEvaluations.Count == 0)
            {
                <div class="sp-note">No upcoming evaluations found.</div>
            }
            else
            {
                @foreach (var item in Model.UpcomingEvaluations)
                {
                    <div class="sp-eval">
                        <span class="sp-dot" style="background:@item.SubjectColorHex"></span>
                        <div>
                            <p class="sp-eval-title">@item.SubjectName</p>
                            <p class="sp-eval-meta">@item.EvaluationTitle<br />@item.DateLabel</p>
                        </div>
                        <span class="sp-pill @item.PillClass">@item.DaysLeft day(s)</span>
                    </div>
                }
            }
        </div>
    </div>
</section>

<section class="sp-panel" aria-label="Weekly goal progress">
    <div class="sp-panel-header">
        <div class="sp-panel-badge" aria-hidden="true" style="background: linear-gradient(145deg, #36b5e8, #4dd4be); color: rgba(255,255,255,0.98); border: 0;">🎯</div>
        <h2 class="sp-panel-title">Weekly Goal</h2>
    </div>
    <div class="sp-panel-body">
        <div style="display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:8px;">
            <strong>@Model.HoursThisWeekLabel studied</strong>
            <span style="color:var(--sp-muted); font-weight:700;">Goal: @Model.WeeklyGoalHours h</span>
        </div>

        <div style="height:12px; border-radius:999px; background:rgba(31,159,245,0.16); overflow:hidden;">
            <div style="height:100%; width:@Model.WeeklyGoalProgressPercent%; background:linear-gradient(90deg,#38bdf8,#34c38f);"></div>
        </div>

        <div style="margin-top:8px; color:var(--sp-muted); font-weight:700;">
            Progress: @Model.WeeklyGoalProgressPercent%
        </div>
    </div>
</section>
</div>